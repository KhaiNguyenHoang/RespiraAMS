{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "SuperSecretKeyForJWTTokenGeneration1234567890!",
    "Issuer": "RespiraAMS",
    "Audience": "RespiraAMS",
    "AccessTokenExpiration": 60,
    "RefreshTokenExpiration": 1440,
    "TokenExpiration": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/Auth/{**catch-all}"
        }
      },
      "profile-route": {
        "ClusterId": "profile-cluster",
        "Match": {
          "Path": "/api/Profile/{**catch-all}"
        }
      },
      "doctor-route": {
        "ClusterId": "doctor-cluster",
        "Match": {
          "Path": "/api/Doctor/{**catch-all}"
        }
      },
      "antibioticspectra-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/AntibioticSpectra/{**catch-all}"
        }
      },
      "antibiotics-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/Antibiotics/{**catch-all}"
        }
      },
      "diagnose-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/Diagnose/{**catch-all}"
        }
      },
      "diseasepathogens-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/DiseasePathogens/{**catch-all}"
        }
      },
      "diseases-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/Diseases/{**catch-all}"
        }
      },
      "icuhospitalize-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/IcuHospitalizeCriteria/{**catch-all}"
        }
      },
      "pathogens-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/Pathogens/{**catch-all}"
        }
      },
      "resistancerisk-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/ResistanceRiskFactors/{**catch-all}"
        }
      },
      "treatment-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/TreatmentProtocols/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authentication-api"
          }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authentication-api"
          }
        }
      },
      "doctor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://doctor-api"
          }
        }
      },
      "app-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://app-api"
          }
        }
      }
    }
  }
}
